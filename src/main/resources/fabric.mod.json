      "dev.muhofy.furnaceboard.FurnaceBoardMod"
    ]
  },

  "depends": {
    "fabricloader": ">=0.18.1",
    "fabric-api": ">=0.140.2+1.21.11",
    "minecraft": "~1.21.11",
    "java": ">=21"
  },

  "suggests": {
    "cloth-config": "*",
    "modmenu": "*"
  }

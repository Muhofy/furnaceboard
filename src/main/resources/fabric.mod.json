{
  "schemaVersion": 1,
  "id": "furnaceboard",
  "version": "${version}",

  "name": "FurnaceBoard",
  "description": "Track all your furnaces at a glance. Get notified when smelting is done.",
  "authors": ["Muhofy"],
  "contact": {
    "sources": "https://github.com/muhofy/furnaceboard"
  },

  "license": "MIT",
  "icon": "assets/furnaceboard/icon.png",

  "environment": "client",

  "entrypoints": {
